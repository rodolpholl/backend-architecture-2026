# ⚠️ ESTE ARQUIVO É APENAS UM EXEMPLO
# NÃO use credenciais reais aqui!
# Em PRODUÇÃO, todas as credenciais devem vir do Vault (HashiCorp Vault)
# Em DESENVOLVIMENTO LOCAL, use este arquivo apenas como referência

# Configurações do PostgreSQL
POSTGRES_USER=agile_admin
POSTGRES_PASSWORD=CHANGE_ME_IN_VAULT
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=en_US.UTF-8
TZ=America/Sao_Paulo

# Configurações do Redis
REDIS_PASSWORD=CHANGE_ME_IN_VAULT
REDIS_PORT=6379

# Configurações do RabbitMQ
RABBITMQ_DEFAULT_USER=agile_user
RABBITMQ_DEFAULT_PASS=CHANGE_ME_IN_VAULT
RABBITMQ_DEFAULT_VHOST=/agile

# Configurações do Vault (Dev Mode)
VAULT_DEV_ROOT_TOKEN_ID=CHANGE_ME_IN_VAULT
VAULT_DEV_LISTEN_ADDRESS=0.0.0.0:8200
VAULT_LOG_LEVEL=info

# Configurações do Grafana
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_IN_VAULT
GF_USERS_ALLOW_SIGN_UP=false

# Configurações de Logging
COMPOSE_FILE=docker-compose.yml
COMPOSE_PROJECT_NAME=agile-workers
